# ---- Telegram ----
BOT_TOKEN=123456:ABC-your-bot-token
ADMIN_IDS=11111111,22222222

# ---- Database (SQLite local; postgres+asyncpg on Railway) ----
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ---- Secrets ----
# ENCRYPTION_KEY MUST be a valid Fernet key: 32 url-safe base64-encoded bytes
# (a 44-character string ending in '='), generated — NOT a custom password.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: if you change this key later, all previously-encrypted panel
# credentials in the database become undecryptable.
ENCRYPTION_KEY=replace-with-generated-fernet-key
# Session signing key for the web dashboard (any long random string)
WEB_SECRET_KEY=change-me-in-production

# ---- Web dashboard ----
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Initial admin created on first launch (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ---- Panel (global connection info only; per-user creds are in the DB) ----
PANEL_BASE_URL=http://168.119.13.175/ints
PANEL_LOGIN_PATH=/login
PANEL_MODE=mock            # switch to "live" when ready

# ---- Daily per-client allocation limit (UK time) ----
DAILY_CLIENT_LIMIT=300
DAILY_LIMIT_TIMEZONE=Europe/London

# ---- Browser / scaling ----
MAX_CONCURRENT_BROWSERS=8
BROWSER_TIMEOUT_MS=30000
REQUEST_TIMEOUT_MS=60000
HEADLESS=true

# ---- Logging ----
LOG_LEVEL=INFO
